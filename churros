#!/usr/bin/env bash

set -e

case "$1" in
    build)
    echo "======================================"
    echo "      ChurrOS Build System"
    echo "======================================"
    echo

    echo "[1/5] Cleaning previous build..."
    sudo rm -rf work out
    mkdir -p out

    echo "[2/5] Preparing branding..."
    rm -rf archiso/airootfs/root/branding
    mkdir -p archiso/airootfs/root/branding

    cp -r branding/files archiso/airootfs/root/branding/
    cp branding/customize_airootfs.sh archiso/airootfs/root/

    echo "[3/5] Building ChurrOS ISO..."
    sudo mkarchiso -v \
        -w work \
        -o out \
        archiso

    echo "[4/5] Cleaning temporary branding..."
    rm -rf archiso/airootfs/root/branding
    rm -f archiso/airootfs/root/customize_airootfs.sh

    echo "[5/5] Done!"
    echo

    find out -name "*.iso"
    
        ;;

    clean)
        echo "==> Cleaning..."
        sudo rm -rf work out
        mkdir -p out
        ;;


run)
    echo "==> Building ChurrOS..."
    "$0" build

    ISO=$(find out -name "*.iso" | head -n1)

    if [ -z "$ISO" ]; then
        echo "No ISO found."
        exit 1
    fi

    echo
    echo "==> Launching QEMU..."
    echo

    qemu-system-x86_64 \
        -enable-kvm \
        -m 4096 \
        -smp 4 \
        -cpu host \
        -cdrom "$ISO" \
        -boot d \
        -display gtk

    ;;

    *)
        echo "ChurrOS Development Tool"
        echo
        echo "Usage:"
        echo "  ./churros build    Build the ISO"
        echo "  ./churros clean    Clean build files"
        ;;


esac
